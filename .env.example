SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_CHANNEL=#general
PROJECTS_DIR=/path/to/your/projects

# --- Plan review via ngrok (optional) ---
# Set NGROK_AUTHTOKEN to enable the `review_plan` MCP tool. When unset, the
# ngrok binary is omitted from the built image and the tool is not registered.
# Get a token from https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=
# Long random shared secret protecting the review URL. Required when
# NGROK_AUTHTOKEN is set. Generate with: openssl rand -hex 32
REVIEW_AUTH_KEY=

# --- Access control (optional) ---
# Leave SECURITY_ENABLED unset or "false" to skip all access checks; the other
# SECURITY_* vars can then be omitted entirely.
SECURITY_ENABLED=false
# Strict mode: empty allowlist = deny all. Flexible mode (false): empty = allow all.
SECURITY_STRICT_MODE=false
# Comma-separated Slack user IDs allowed to use the bot (e.g. U0123ABC,U0456DEF)
SECURITY_ALLOWED_USERS=
# Comma-separated Slack channel IDs the bot will respond in (e.g. C0123ABC,C0456DEF)
SECURITY_ALLOWED_CHANNELS=
# Comma-separated user IDs that bypass the channel allowlist
SECURITY_ADMIN_USERS=
# Message posted back to unauthorized users
SECURITY_REJECTION_MESSAGE=You are not authorized to use this bot.
# Emit a warning log line on each denial
SECURITY_LOG_UNAUTHORIZED=true
